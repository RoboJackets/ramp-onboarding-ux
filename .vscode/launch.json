{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Flask",
            "type": "debugpy",
            "request": "launch",
            "module": "flask",
            "env": {
                "FLASK_APP": "ramp_onboarding_ux.py",
                "FLASK_DEBUG": "1",
                "FLASK_CACHE_TYPE": "SimpleCache"
            },
            "envFile": "${workspaceFolder}/.env",
            "args": [
                "run",
                "--no-debugger"
            ],
            "jinja": true,
            "autoStartBrowser": false
        },
        {
            "name": "Celery",
            "type": "debugpy",
            "request": "launch",
            "module": "celery",
            "env": {
                "FLASK_DEBUG": "1",
                "FLASK_CACHE_TYPE": "SimpleCache"
            },
            "envFile": "${workspaceFolder}/.env",
            "args": [
                "--app",
                "ramp_onboarding_ux.celery_app",
                "worker",
                "--loglevel",
                "DEBUG",
                "--pool",
                "solo"
            ],
            "jinja": true,
            "autoStartBrowser": false
        }
    ]
}